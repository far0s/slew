{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["controls", "renderer"],
  "permissions": [
    "updater:default",
    "core:default",
    "core:window:default",
    "core:event:default",
    "window-state:allow-restore-state",
    "window-state:allow-save-window-state",
    "mcp-bridge:default",
    "dialog:allow-save",
    "dialog:allow-open"
  ]
}
