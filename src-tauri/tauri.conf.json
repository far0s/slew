{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Slew",
  "version": "0.7.3",
  "identifier": "com.seb.slew",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "renderer",
        "title": "Slew — Renderer",
        "width": 1920,
        "height": 1080,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "visible": true,
        "center": true,
        "url": "/renderer"
      },
      {
        "label": "controls",
        "title": "Slew — Controls",
        "width": 1440,
        "height": 1080,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "visible": true,
        "center": true,
        "url": "/"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Entertainment",
    "shortDescription": "VJ software for creative coders",
    "longDescription": "Slew is a modular VJ engine for real-time visual performance. Features include dual-window architecture (renderer + controls), scene system with crossfading, MIDI/OSC/HID input, audio-reactive parameters with FFT analysis, LFO modulation, and video output via Syphon (macOS) and NDI.",
    "copyright": "© 2024 Seb",
    "publisher": "Seb",
    "macOS": {
      "frameworks": ["./frameworks/Syphon.framework"],
      "minimumSystemVersion": "11.0",
      "entitlements": "./entitlements.plist",
      "signingIdentity": null,
      "providerShortName": null,
      "dmg": {
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 },
        "windowSize": { "width": 660, "height": 400 }
      }
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "wix": null,
      "nsis": {
        "installerIcon": "./icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null,
        "installMode": "currentUser",
        "languages": ["English"],
        "displayLanguageSelector": false
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      },
      "deb": {
        "depends": ["libasound2", "libhidapi-dev"]
      }
    }
  }
}
